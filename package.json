{
  "name": "codex-switcher",
  "private": true,
  "version": "1.0.0",
  "description": "A multi-account manager for Codex CLI",
  "type": "module",
  "scripts": {
    "dev": "wails dev",
    "build:frontend": "tsc && vite build",
    "build:backend": "bun build src-electron/lan-entry.ts --outfile=dist-electron/lan.js --target=node",
    "build": "bun run build:frontend && bun run build:backend",
    "dev:wails": "wails dev",
    "build:wails": "wails build -clean -ldflags \"-s -w\"",
    "build:windows": "node scripts/build-windows.mjs",
    "preview": "vite preview",
    "lan": "bun run build && bun dist-electron/lan.js",
    "version:bump": "node scripts/bump-version.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@noble/ciphers": "^2.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
